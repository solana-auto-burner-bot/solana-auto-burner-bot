########################################
# AutoBurner CLI
# Copy this file to .env and fill in your own values.
# Your real .env stays local and should not be committed.
########################################

# Optional log branding shown in the CLI output.
LOG_BRAND=AutoBurner

# RPC setup
HELIUS_API_KEY=
RPC_URLS=https://mainnet.helius-rpc.com/?api-key=${HELIUS_API_KEY},https://api.mainnet-beta.solana.com

# Required wallet + target token
WALLET_SECRET_KEY_BASE58=
MINT=

# Claim routing
POOL=auto
CLAIM_POOL=pump
CLAIM_METHOD=local
CLAIM_REF_SIG=
PUMPPORTAL_API_KEY=

# Optional user treasury split from claimed creator rewards
CLAIM_TREASURY_ADDRESS=
CLAIM_TREASURY_BPS=0

# Optional developer treasury split from claimed creator rewards
# Keep this explicit if you use it.
DEVELOPER_TREASURY_ADDRESS=
DEVELOPER_TREASURY_BPS=0

# Buy behavior
BUY_ROUTE=jupiter
BUY_SPLIT_COUNT=5
SLIPPAGE=1
PRIORITY_FEE=0.0001
INTERVAL_MS=61000
MIN_SOL_KEEP=0.01
BUY_SOL_FEE_BUFFER=0.00005
MIN_BUY_SOL=0.0005
AUTO_CONVERT_INCOMING_TOKENS=1

# Claim behavior
CLAIM_MIN_SOL=0
CLAIM_COOLDOWN_CYCLES=0

# Price guard
PRICE_GUARD_MODE=off
MAX_PRICE_DEVIATION_PCT=15
PRICE_QUOTE_SOL_LAMPORTS=100000000

# Optional quote/price API keys
JUPITER_API_KEY=
BIRDEYE_API_KEY=

# HTTP timeout for external API calls
FETCH_TIMEOUT_MS=8000
